# ═══════════════════════════════════════════════════════════════
# Roxabi Boilerplate — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# Uncommented vars are REQUIRED for local dev.
# Commented vars are OPTIONAL (enable as needed).
# ═══════════════════════════════════════════════════════════════

# ─── Application (Required) ──────────────────────────────────
APP_PORT=3000              # Frontend dev server port (Vite)
API_PORT=4000              # API dev server port (NestJS). On Vercel, PORT is injected by the platform.
NITRO_PORT=42069           # Nitro SSR dev server port (must differ from API_PORT)
EMAIL_PORT=3001            # React Email preview server port
APP_URL=http://localhost:3000   # Frontend URL (used for redirects, emails)
API_URL=http://localhost:4000   # API URL (used by frontend for API calls)
CORS_ORIGIN=http://localhost:3000  # Must match APP_URL exactly
LOG_LEVEL=debug            # debug | info | warn | error

# ─── Database (Required) ─────────────────────────────────────
# On Vercel: auto-injected by Neon Marketplace integration
# DATABASE_URL is used by migrations (connects as schema owner).
# DATABASE_APP_URL is used by the app at runtime (connects as roxabi_app, RLS enforced).
DATABASE_URL=postgresql://roxabi:roxabi@localhost:5432/roxabi
DATABASE_APP_URL=postgresql://roxabi_app:roxabi_app@localhost:5432/roxabi

# ─── Authentication (Required) ───────────────────────────────
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string  # Generate: openssl rand -hex 16
BETTER_AUTH_URL=http://localhost:3000  # Must point to the web app (Nitro proxies /api/** to the API)

# ─── Authentication — OAuth Providers (Optional) ─────────────
# Enable social login by uncommenting and filling in credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ─── Email — Resend (Optional) ───────────────────────────────
# On Vercel: auto-injected by Resend Marketplace integration
# RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# ─── Docker (Optional — override to run multiple projects on the same machine) ─
# APP_SLUG=myapp                       # base slug for container/volume names (default: "app")
# POSTGRES_CONTAINER=myapp-postgres    # override container name (default: ${APP_SLUG}-postgres)
# MAILPIT_CONTAINER=myapp-mailpit      # override container name (default: ${APP_SLUG}-mailpit)
# POSTGRES_VOLUME=myapp_postgres_data  # override volume name (default: ${APP_SLUG}_postgres_data)
# MAILPIT_SMTP_PORT=1025               # host port for SMTP (change to avoid conflicts)
# MAILPIT_UI_PORT=8025                 # host port for web UI (change to avoid conflicts)
# DB_BRANCH_PREFIX=myapp               # prefix for per-worktree branch DBs (default: POSTGRES_DB)

# ─── Email — Mailpit (dev SMTP relay) ────────────────────────
# Start with: bun run db:up (runs alongside Postgres in Docker)
# Web UI: http://localhost:8025
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
# Set to true for remote SMTP relay with TLS (default: false for Mailpit localhost)
SMTP_SECURE=false

# ─── Rate Limiting — Upstash Redis (Optional) ────────────────
# On Vercel: auto-injected by Upstash Marketplace integration
# Required for rate limiting to work; without these, rate limiting is disabled
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
RATE_LIMIT_ENABLED=false
# SWAGGER_ENABLED=true
# RATE_LIMIT_GLOBAL_TTL=60000      # ms — global rate limit window
# RATE_LIMIT_GLOBAL_LIMIT=60       # requests per window
# RATE_LIMIT_AUTH_TTL=60000         # ms — auth endpoint window
# RATE_LIMIT_AUTH_LIMIT=5           # auth requests per window
# RATE_LIMIT_AUTH_BLOCK_DURATION=300000  # ms — block duration after limit hit
# RATE_LIMIT_API_TTL=60000          # ms — general API window
# RATE_LIMIT_API_LIMIT=100          # API requests per window

# ─── Vercel Dashboard (Optional) ────────────────────────────
# VERCEL_TOKEN=
# VERCEL_PROJECT_ID=
# VERCEL_TEAM_ID=
# VERCEL_TEAM_SLUG=roxabi

# ─── Vercel Preview — Deployment Protection (Optional) ─────
# Bypass secret from API project's "Protection Bypass for Automation" setting.
# Set on the Web project (preview only) so server-side API calls pass through SSO.
# VERCEL_AUTOMATION_BYPASS_SECRET=

# ─── Cron Jobs (Optional) ────────────────────────────────────
# Vercel injects via Authorization: Bearer header
# CRON_SECRET=change-me-to-a-random-secret

# ─── Claude Code (Optional) ──────────────────────────────────
CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1  # Enable multi-agent coordination

# ─── External Services (Optional) ────────────────────────────
# GITHUB_TOKEN=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ─── Public (Exposed to Client — NEVER put secrets here) ────
# WARNING: VITE_ prefixed vars are bundled into client JS and visible to all users.
VITE_GITHUB_REPO_URL=https://github.com/Roxabi/roxabi-boilerplate
# VITE_TALKS_URL=https://talks.roxabi.com
# VITE_DOCS_URL=https://dev.roxabi.com

# ═══════════════════════════════════════════════════════════════
# Configuration Examples
# ═══════════════════════════════════════════════════════════════

# --- Example: Local Dev (default — just copy .env.example to .env) ---
# All required vars above have sensible defaults. Run:
#   cp .env.example .env && bun install && bun dev

# --- Example: Vercel Preview ---
# Most vars are auto-injected by Marketplace integrations (Neon, Resend, Upstash).
# You only need to set manually:
#   BETTER_AUTH_SECRET=<random-32-char-string>
#   APP_URL=https://your-preview-url.vercel.app
#   CORS_ORIGIN=https://your-preview-url.vercel.app

# --- Example: VPS / Self-Hosted Production ---
# NODE_ENV=production
# APP_PORT=3000
# API_PORT=4000
# APP_URL=https://app.example.com
# API_URL=https://api.example.com
# DATABASE_URL=postgresql://owner:pass@clouddb:5432/roxabi
# DATABASE_APP_URL=postgresql://app_user:pass@clouddb:5432/roxabi
# CORS_ORIGIN=https://app.example.com
# BETTER_AUTH_SECRET=<random-32-char-string>
# BETTER_AUTH_URL=https://app.example.com
# EMAIL_FROM=noreply@example.com
# RESEND_API_KEY=re_<your-resend-api-key>
# KV_REST_API_URL=https://xxx.upstash.io
# KV_REST_API_TOKEN=xxx

# --- dev-core: GitHub Project V2 ---
# Run /init to auto-detect these values
GITHUB_REPO=owner/repo
GH_PROJECT_ID=PVT_...
STATUS_FIELD_ID=PVTSSF_...
SIZE_FIELD_ID=PVTSSF_...
PRIORITY_FIELD_ID=PVTSSF_...

# --- dev-core: Field option IDs (auto-detected by /init) ---
STATUS_OPTIONS_JSON={}
SIZE_OPTIONS_JSON={}
PRIORITY_OPTIONS_JSON={}

# --- dev-core: Vercel (optional — for dashboard deployments panel) ---
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# --- dev-core: GitHub token (optional — falls back to `gh auth token`) ---
GITHUB_TOKEN=
