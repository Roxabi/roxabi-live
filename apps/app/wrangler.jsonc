{
  // Local dev config for apps/app
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "roxabi-live-app-dev",
  "main": "worker.ts",
  "compatibility_date": "2025-06-01",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": true
  }
}
