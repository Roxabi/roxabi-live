---
import type { Translations } from "../i18n/index";

interface Props {
  t: Translations;
}
const { t } = Astro.props;
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-inner">
      <a href="/" class="footer-logo" aria-label="Roxabi Live">
        <span class="logo-mark" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <rect x="1" y="1" width="5" height="5" rx="1" fill="#f59e0b"/>
            <rect x="8" y="1" width="5" height="5" rx="1" fill="#f59e0b"/>
            <rect x="1" y="8" width="5" height="5" rx="1" fill="#f59e0b"/>
            <rect x="8" y="8" width="5" height="5" rx="1" fill="#f59e0b" opacity=".4"/>
          </svg>
        </span>
        <span class="footer-wordmark">Roxabi <span>{t.footer.logoWordmark}</span></span>
      </a>

      <ul class="footer-links" role="list">
        {t.footer.links.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>

      <p class="footer-copy">{t.footer.copy}</p>
    </div>
  </div>
</footer>
