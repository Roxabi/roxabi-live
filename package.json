{
  "name": "roxabi-live",
  "private": true,
  "license": "AGPL-3.0-only",
  "packageManager": "bun@1.3.14",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev:marketing": "bun --filter @roxabi-live/marketing dev",
    "build:marketing": "bun --filter @roxabi-live/marketing build",
    "build": "bun --filter @roxabi-live/marketing build",
    "typecheck": "bun run --filter '@roxabi-live/*' typecheck",
    "deploy:production": "bash scripts/deploy-production.sh",
    "deploy:staging": "bash scripts/deploy-staging.sh",
    "setup:workers-builds": "node scripts/setup-workers-builds.mjs",
    "verify:cloudflare": "node scripts/verify-cloudflare.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0"
  }
}
