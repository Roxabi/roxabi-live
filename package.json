{
  "name": "roxabi-dashboard",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "bash scripts/prepare.sh",
    "dev": "set -a; [ -f .env ] && . .env; set +a; bash scripts/predev.sh && turbo dev",
    "dev:web": "set -a; [ -f .env ] && . .env; set +a; turbo dev --filter=@repo/web",
    "dev:api": "set -a; [ -f .env ] && . .env; set +a; turbo dev --filter=@repo/api",
    "dev:clean": "set -a; [ -f .env ] && . .env; set +a; fuser -k ${NITRO_PORT:-42069}/tcp ${API_PORT:-4000}/tcp ${APP_PORT:-3000}/tcp ${EMAIL_PORT:-3001}/tcp 2>/dev/null || true",
    "build": "turbo build",
    "lint": "biome check --diagnostic-level=warn .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "clean": "turbo clean && rm -rf node_modules",
    "clean:cache": "rm -rf apps/web/node_modules/.vite .turbo apps/*/.turbo packages/*/.turbo",
    "docs": "turbo dev --filter=@repo/web",
    "i18n:check": "bun run scripts/validateTranslations.ts",
    "typecheck:affected": "turbo run typecheck --filter=...[origin/main]",
    "test:affected": "turbo run test --filter=...[origin/main]",
    "license:check": "bun run tools/licenseChecker.ts",
    "docs:links": "bun run tools/docsLinkAudit.ts",
    "docs:frontmatter": "bun run tools/docsFrontmatterCheck.ts",
    "docs:check": "bun run docs:links && bun run docs:frontmatter",
    "env:check": "bun run scripts/checkEnvSync.ts",
    "vercel:env:check": "bun run scripts/checkVercelEnv.ts",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:generate": "bash scripts/db.sh generate",
    "db:migrate": "bash scripts/db.sh migrate",
    "db:reset": "bash scripts/db.sh reset",
    "db:seed": "bash scripts/db.sh seed",
    "dashboard": "bun ~/projects/roxabi-plugins/plugins/dev-core/skills/issues/dashboard.ts"
  },
  "devDependencies": {
    "@types/node": "^24.11.0",
    "@biomejs/biome": "^2.4.5",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@huggingface/transformers": "^3.8.1",
    "@playwright/test": "^1.58.2",
    "@repo/playwright-config": "workspace:*",
    "@repo/vitest-config": "workspace:*",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.1.0",
    "lefthook": "^2.1.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sqlite-vec": "0.1.8",
    "turbo": "^2.8.12",
    "turbo-ignore": "^2.8.12",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "yaml": "^2.8.2"
  },
  "packageManager": "bun@1.3.9",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/press-start-2p": "^5.2.7",
    "fumadocs-mdx": "^14.2.9",
    "lucide-react": "^0.576.0",
    "shiki": "^4.0.1"
  },
  "overrides": {
    "minimatch": ">=10.2.3",
    "lodash": ">=4.17.23",
    "rollup": ">=4.59.0",
    "ajv": ">=6.14.0"
  },
  "resolutions": {
    "@types/node": "24.11.0"
  }
}
