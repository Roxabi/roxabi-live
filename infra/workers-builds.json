{
  "_note": "UNAPPLIED — CF Workers Builds was never connected (no Cloudflare GitHub App). Staging auto-deploy lives in .github/workflows/deploy-staging.yml. Do not treat this file as live infra.",
  "accountId": "b5e90be971920ce406f7b679c4f1cd33",
  "github": {
    "owner": "Roxabi",
    "ownerId": 130185740,
    "repo": "roxabi-live",
    "repoId": 1175843511
  },
  "pathIncludes": ["apps/*", "packages/*", "scripts/deploy-*.sh", "bun.lock"],
  "pathExcludes": [],
  "workers": [
    {
      "workerName": "roxabi-live",
      "trigger": {
        "name": "Deploy production (api)",
        "rootDirectory": "/",
        "buildCommand": "bun install --frozen-lockfile",
        "deployCommand": "bash scripts/deploy-production.sh",
        "branchIncludes": ["main"],
        "branchExcludes": []
      }
    },
    {
      "workerName": "roxabi-live-staging",
      "trigger": {
        "name": "Deploy staging (api)",
        "rootDirectory": "/",
        "buildCommand": "bun install --frozen-lockfile",
        "deployCommand": "bash scripts/deploy-staging.sh",
        "branchIncludes": ["staging"],
        "branchExcludes": []
      }
    },
    {
      "workerName": "roxabi-live-app",
      "trigger": {
        "name": "Deploy production (SPA)",
        "rootDirectory": "/",
        "buildCommand": "bun install --frozen-lockfile && bun --filter @roxabi-live/app build",
        "deployCommand": "cd apps/app && bunx wrangler deploy --config wrangler.deploy.jsonc",
        "branchIncludes": ["main"],
        "branchExcludes": []
      }
    }
  ]
}
