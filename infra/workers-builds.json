  "_note": "SSOT — API only (enishu model). Frontends = CF Pages (infra/pages-*.json). Apply: source scripts/bw-cloudflare-live-build-env.sh && CLOUDFLARE_API_TOKEN=$CLOUDFLARE_BUILDS_ADMIN_TOKEN bun run setup:workers-builds",
  "accountId": "b5e90be971920ce406f7b679c4f1cd33",
