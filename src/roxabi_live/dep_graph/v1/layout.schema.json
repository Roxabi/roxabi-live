{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "dep-graph layout.json schema (multi-repo)",
  "description": "Minimal layout.json: only meta + lanes[code/name/color] are required. order/par_groups/bands/extra_deps/cross_deps/title_rules are all optional — when absent they are auto-derived from GitHub metadata.",
  "type": "object",
  "required": ["meta", "lanes"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["title", "date", "repos", "label_prefix"],
      "additionalProperties": false,
      "not": { "required": ["repo"] },
      "properties": {
        "title":        { "type": "string" },
        "date":         { "type": "string", "format": "date" },
        "repos":        { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "label_prefix": { "type": "string", "description": "e.g. graph:" },
        "issue":        { "$ref": "#/$defs/IssueRef" },
        "category":     { "type": "string" },
        "cat_label":    { "type": "string" },
        "color":        { "type": "string" }
      }
    },
    "lanes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "name", "color"],
        "additionalProperties": false,
        "properties": {
          "code":  { "type": "string" },
          "name":  { "type": "string" },
          "color": { "type": "string" },
          "epic": {
            "oneOf": [
              { "type": "null" },
              {
                "type": "object",
                "required": ["issue", "label", "tag"],
                "additionalProperties": false,
                "properties": {
                  "issue": { "type": "integer" },
                  "label": { "type": "string" },
                  "tag":   { "type": "string" },
                  "defer": { "type": "boolean" }
                }
              }
            ]
          },
          "order": {
            "description": "OPTIONAL: explicit display order. When absent, auto-derived from gh_issues topo-sort.",
            "type": "array",
            "items": { "$ref": "#/$defs/IssueRef" }
          },
          "par_groups": {
            "description": "OPTIONAL: parallel groups. When absent, auto-derived from topo depth.",
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": { "$ref": "#/$defs/IssueRef" }
            }
          },
          "bands": {
            "description": "OPTIONAL: milestone band headers. When absent, auto-derived from GH milestone field.",
            "type": "array",
            "items": {
              "type": "object",
              "required": ["before", "text"],
              "additionalProperties": false,
              "properties": {
                "before": { "$ref": "#/$defs/IssueRef" },
                "text":   { "type": "string" }
              }
            }
          }
        }
      }
    },
    "milestones": {
      "description": "OPTIONAL: milestone rows for the grid view. When absent, falls back to hardcoded defaults in v5/data/model.py::MILESTONES. 'label' must match the GitHub milestone title (em-dashes stripped to double-space); 'code' is the short code (e.g. 'M0'); 'short' is the display name for row headers.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "code", "short"],
        "additionalProperties": false,
        "properties": {
          "label": { "type": "string" },
          "code":  { "type": "string" },
          "short": { "type": "string" }
        }
      }
    },
    "column_groups": {
      "description": "OPTIONAL: column groups for the grid view. When absent, falls back to hardcoded defaults in v5/data/model.py::COLUMN_GROUPS. Each group bundles 1+ lane codes under a single column header. 'tone' is the CSS tone key used for the header color.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "tone", "lane_codes"],
        "additionalProperties": false,
        "properties": {
          "label":      { "type": "string" },
          "tone":       { "type": "string" },
          "lane_codes": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        }
      }
    },
    "standalone": {
      "description": "OPTIONAL: standalone section. When order[] is absent, empty, or the entire object is {} (all three forms are equivalent), the section is auto-derived from graph:standalone labels.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "order": {
          "type": "array",
          "items": { "$ref": "#/$defs/IssueRef" }
        }
      }
    },
    "overrides": {
      "description": "OPTIONAL: per-issue editorial overrides. Only anchor, anchor_after, extra_deps_ext, status are meaningful. title and size are deprecated (title_rules now global, size read from GH labels).",
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^[^/]+/[^/]+#\\d+$": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "title":          { "type": "string", "description": "Deprecated: use GH title + title_rules instead." },
            "size":           { "type": "string", "description": "Deprecated: use size:* GH label instead." },
            "status":         { "type": "string", "enum": ["done", "ready", "blocked", "defer"] },
            "anchor":         { "type": "string" },
            "anchor_after":   { "type": "string" },
            "extra_deps_ext": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "extra_deps": {
      "description": "DEPRECATED: add blocked_by relationships directly on GitHub instead.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "extra_blocked_by": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^[^/]+/[^/]+#\\d+$": {
              "type": "array",
              "items": { "type": "string", "pattern": "^[^/]+/[^/]+#\\d+$" }
            }
          }
        },
        "extra_blocking": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^[^/]+/[^/]+#\\d+$": {
              "type": "array",
              "items": { "type": "string", "pattern": "^[^/]+/[^/]+#\\d+$" }
            }
          }
        }
      }
    },
    "cross_deps": {
      "description": "OPTIONAL: editorial cross-lane dependency notes (rendered in footer section).",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "text"],
        "additionalProperties": false,
        "properties": {
          "kind": { "type": "string" },
          "text": { "type": "string" }
        }
      }
    },
    "title_rules": {
      "description": "DEPRECATED: built-in rules in titles.py handle conventional-commit stripping globally. Only add here for project-specific overrides applied BEFORE built-ins.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pattern", "replacement"],
        "additionalProperties": false,
        "properties": {
          "pattern":     { "type": "string" },
          "replacement": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "IssueRef": {
      "type": "object",
      "required": ["repo", "issue"],
      "additionalProperties": false,
      "properties": {
        "repo":  { "type": "string", "pattern": "^[^/]+/[^/]+$" },
        "issue": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
